<resources>
    <style name="Theme.SpellTracker" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/midnight_blue</item>
        <item name="colorPrimaryDark">@color/midnight_blue_dark</item>
        <item name="colorPrimaryVariant">@color/midnight_blue_light</item>
        <item name="colorOnPrimary">@color/text_on_dark</item>

        <item name="colorSecondary">@color/earth_green</item>
        <item name="colorSecondaryVariant">@color/earth_green_dark</item>
        <item name="colorOnSecondary">@color/text_on_dark</item>
        <item name="colorAccent">@color/earth_green</item>

        <item name="android:windowBackground">@color/beige</item>
        <item name="android:colorBackground">@color/beige</item>
        <item name="colorSurface">@color/beige_light</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <item name="android:statusBarColor">@color/midnight_blue_dark</item>
        <item name="android:navigationBarColor">@color/midnight_blue_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- Rounded, filled "primary" button: midnight blue background -->
    <style name="Widget.SpellTracker.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/midnight_blue</item>
        <item name="android:textColor">@color/text_on_dark</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- Rounded, filled "accent" button: earth green background -->
    <style name="Widget.SpellTracker.Button.Accent" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/earth_green</item>
        <item name="android:textColor">@color/text_on_dark</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- Outlined button for secondary / optional actions -->
    <style name="Widget.SpellTracker.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/midnight_blue_light</item>
        <item name="android:textColor">@color/midnight_blue</item>
        <item name="cornerRadius">24dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <!-- Small icon-only button (delete, etc.) -->
    <style name="Widget.SpellTracker.Button.Icon" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/mistake_red</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Card used for every section/list item -->
    <style name="Widget.SpellTracker.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/beige_dark</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">@color/beige_light</item>
    </style>

    <!-- Text input box style -->
    <style name="Widget.SpellTracker.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxStrokeColor">@color/midnight_blue_light</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>
</resources>
