<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beige">

    <!-- Header -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/midnight_blue"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="36dp"
        android:paddingBottom="28dp">

        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_circle_badge"
            android:layout_marginBottom="12dp">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_check" />
        </FrameLayout>

        <TextView
            android:text="Spell Tracker"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_on_dark"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:text="Catch your spelling mistakes as you type, and practice the words that trip you up."
            android:textSize="14sp"
            android:textColor="@color/text_on_dark_muted"
            android:layout_marginTop="4dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <!-- Consent card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.SpellTracker.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:text="Step 1 · Consent"
                        android:textColor="@color/earth_green_dark"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:text="This app only checks spelling after you say yes, and only ever saves misspelled words — never anything else you type."
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="14dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/consentSwitch"
                        android:text="Track my spelling mistakes"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        app:thumbTint="@color/earth_green"
                        app:trackTint="@color/earth_green_light"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Tracking method card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.SpellTracker.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:text="Step 2 · Turn on tracking"
                        android:textColor="@color/earth_green_dark"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:text="Works with any keyboard you already use."
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="14dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/enableAccessibilityButton"
                        style="@style/Widget.SpellTracker.Button.Primary"
                        android:text="Open Accessibility Settings"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/beige_dark"
                        android:layout_marginTop="18dp"
                        android:layout_marginBottom="14dp" />

                    <TextView
                        android:text="Or use Spell Tracker's own keyboard instead (optional)"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/enableKeyboardButton"
                        style="@style/Widget.SpellTracker.Button.Outlined"
                        android:text="Open Keyboard Settings"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/chooseKeyboardButton"
                        style="@style/Widget.SpellTracker.Button.Outlined"
                        android:text="Switch to Spell Tracker Keyboard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Report interval card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.SpellTracker.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:text="Step 3 · Report frequency"
                        android:textColor="@color/earth_green_dark"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                    <TextView
                        android:text="How often should we check in with a summary?"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="14dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <LinearLayout
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.SpellTracker.TextInputLayout"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:hint="Hours">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/intervalEditText"
                                android:inputType="number"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/saveIntervalButton"
                            style="@style/Widget.SpellTracker.Button.Accent"
                            android:text="Save"
                            android:layout_marginStart="12dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Navigation -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/viewReportButton"
                style="@style/Widget.SpellTracker.Button.Primary"
                android:text="View Mistake Report"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/practiceListButton"
                style="@style/Widget.SpellTracker.Button.Accent"
                android:text="My Practice List"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
