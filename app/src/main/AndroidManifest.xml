<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Needed to show the periodic report notification -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:label="Spell Tracker"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.SpellTracker"
        android:supportsRtl="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="Spell Tracker">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ReportActivity"
            android:exported="false"
            android:label="Mistake Report" />

        <activity
            android:name=".PracticeListActivity"
            android:exported="false"
            android:label="Practice List" />

        <!-- Tracks typing across any app/keyboard, to check spelling.
             Requires the user to manually enable it in Settings > Accessibility. -->
        <service
            android:name=".ime.SpellTrackerAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true"
            android:label="Spell Tracker">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- The custom keyboard (Input Method Editor) that does the typing tracking -->
        <service
            android:name=".ime.SpellTrackerIME"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true"
            android:label="Spell Tracker Keyboard">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>

    </application>
</manifest>
